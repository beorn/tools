{
  "name": "bearly",
  "version": "0.0.0",
  "private": true,
  "description": "Reusable Claude Code tools — coordination, testing, research, refactoring",
  "keywords": [
    "ai",
    "batch-refactor",
    "claude-code",
    "codemod",
    "developer-tools",
    "gemini",
    "gpt",
    "llm",
    "multi-llm",
    "refactoring",
    "session-search",
    "ts-morph",
    "tty",
    "worktree"
  ],
  "license": "MIT",
  "author": "Beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "tools",
    "skills"
  ],
  "type": "module",
  "exports": {
    "./tools/worktree": "./tools/worktree.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "refactor": "bun tools/refactor.ts",
    "llm": "bun tools/llm.ts",
    "recall": "bun tools/recall.ts",
    "tribe": "bun tools/tribe-cli.ts",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "fix": "oxfmt --write ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.63",
    "@ai-sdk/google": "^3.0.52",
    "@ai-sdk/openai": "^3.0.47",
    "@ai-sdk/perplexity": "^3.0.25",
    "@ai-sdk/xai": "^3.0.72",
    "@bearly/bg-recall": "workspace:*",
    "@bearly/tribe-client": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@silvery/commander": "^0.21.0",
    "@termless/core": "^0.6.0",
    "@termless/xtermjs": "^0.3.1",
    "ai": "^6.0.134",
    "commander": "^14.0.3",
    "loggily": "^0.10.0",
    "openai": "^6.32.0",
    "playwright": "^1.59.1",
    "ts-morph": "^24.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "oxfmt": "^0.38.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.13",
    "node": ">=23.6.0"
  }
}
