{
  "name": "claude-tty-mcp",
  "version": "0.1.0",
  "description": "Headless terminal testing MCP server — PTY + xterm.js emulation",
  "license": "MIT",
  "bin": "./server.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./server.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": "./dist/server.mjs",
    "exports": {
      ".": {
        "types": "./dist/server.d.mts",
        "import": "./dist/server.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "start": "bun install --no-summary && bun server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@termless/core": "^0.6.0",
    "@termless/xtermjs": "^0.3.1",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsdown": "^0.21.7"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "server.ts",
    "external": [
      "@modelcontextprotocol/sdk",
      "@termless/core",
      "@termless/xtermjs",
      "playwright",
      "zod"
    ],
    "format": "esm"
  }
}
