{
  "name": "vitepress-enrich",
  "version": "0.4.1",
  "description": "Glossary auto-linking, content linkification, SEO helpers, and tooltip CSS for VitePress sites",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly",
    "directory": "packages/vitepress-enrich"
  },
  "files": [
    "dist",
    "src/css"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./glossary": "./src/glossary.ts",
    "./linkify": "./src/linkify.ts",
    "./seo": "./src/seo.ts",
    "./validate": "./src/validate.ts",
    "./terminal-glossary": "./src/terminal-glossary.ts",
    "./terminfo": "./src/terminfo.ts",
    "./doc-glossary": "./src/doc-glossary.ts",
    "./ecosystem-glossary": "./src/ecosystem-glossary.ts",
    "./css/tooltip.css": "./src/css/tooltip.css",
    "./css/glossary-links.css": "./src/css/glossary-links.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./glossary": {
        "types": "./dist/glossary.d.mts",
        "import": "./dist/glossary.mjs"
      },
      "./linkify": {
        "types": "./dist/linkify.d.mts",
        "import": "./dist/linkify.mjs"
      },
      "./seo": {
        "types": "./dist/seo.d.mts",
        "import": "./dist/seo.mjs"
      },
      "./validate": {
        "types": "./dist/validate.d.mts",
        "import": "./dist/validate.mjs"
      },
      "./terminal-glossary": {
        "types": "./dist/terminal-glossary.d.mts",
        "import": "./dist/terminal-glossary.mjs"
      },
      "./terminfo": {
        "types": "./dist/terminfo.d.mts",
        "import": "./dist/terminfo.mjs"
      },
      "./doc-glossary": {
        "types": "./dist/doc-glossary.d.mts",
        "import": "./dist/doc-glossary.mjs"
      },
      "./ecosystem-glossary": {
        "types": "./dist/ecosystem-glossary.d.mts",
        "import": "./dist/ecosystem-glossary.mjs"
      },
      "./css/tooltip.css": "./src/css/tooltip.css",
      "./css/glossary-links.css": "./src/css/glossary-links.css"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "devDependencies": {
    "tsdown": "^0.21.7"
  },
  "peerDependencies": {
    "markdown-it": ">=14",
    "vitepress": ">=1"
  },
  "peerDependenciesMeta": {
    "markdown-it": {
      "optional": true
    },
    "vitepress": {
      "optional": true
    }
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/glossary.ts",
      "src/linkify.ts",
      "src/seo.ts",
      "src/validate.ts",
      "src/terminal-glossary.ts",
      "src/terminfo.ts",
      "src/doc-glossary.ts",
      "src/ecosystem-glossary.ts"
    ],
    "format": "esm"
  },
  "engines": {
    "node": ">=18"
  }
}
