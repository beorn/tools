{
  "name": "@bearly/bounded-queue",
  "version": "0.1.0",
  "private": true,
  "description": "Coordination primitive — bounded queue with explicit drop policy and always-on O(1) depth gauge. Sibling to @bearly/tribe-client and @bearly/bg-recall.",
  "keywords": [
    "bounded-queue",
    "backpressure",
    "coordination",
    "observability",
    "drop-policy"
  ],
  "homepage": "https://github.com/beorn/bearly/tree/main/packages/bounded-queue",
  "bugs": {
    "url": "https://github.com/beorn/bearly/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/bearly.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "node": ">=23.6.0"
  }
}
